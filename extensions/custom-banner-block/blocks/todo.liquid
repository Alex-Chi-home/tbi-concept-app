{% assign button_id = 'credit-button-' | append: block.id %}
{% assign iframe_wrapper_id = 'credit-iframe-wrapper-' | append: block.id %}

<div {{ block.shopify_attributes }}>
  <button
    id="{{ button_id }}"
    type="button"
    style="padding: 12px 20px; cursor: pointer;"
  >
    Рассчитать кредит
  </button>

  <div id="{{ iframe_wrapper_id }}" hidden style="margin-top: 16px;">
    <iframe
      src="http://localhost:3000/calculator"
      title="Калькулятор кредита"
      width="800"
      height="500"
      loading="lazy"
      style="max-width: 100%; border: 0;"
    ></iframe>
  </div>
</div>

<script>
  (() => {
    const button = document.getElementById('{{ button_id }}');
    const iframeWrapper = document.getElementById('{{ iframe_wrapper_id }}');

    if (!button || !iframeWrapper) return;

    window.addEventListener("message", function(event) {
    if (event.data?.type !== "TO_CART_EVENT") {
        return
    }

    {% comment %} if (window.location.pathname === "/cart") {
        return
    } {% endcomment %}
    window.location.href = window.Shopify.routes.root + "cart";
    {% comment %} window.location.href = "https://alex-chi-store.myshopify.com/cart" {% endcomment %}
    {% comment %} window.history.pushState({}, "", "/cart") {% endcomment %}
})

    window.addEventListener("message", function(event) {
    if (event.data?.type !== "ADD_TO_CART_EVENT") {
        return
    }


    window.location.href = window.Shopify.routes.root + "cart";
  
})

    button.addEventListener('click', () => {
      iframeWrapper.hidden = false;
      button.style.display = 'none';
    });
  })();
</script>

{% schema %}
{
  "name": "Credit calculator",
  "target": "section",
  "settings": []
}
{% endschema %}

